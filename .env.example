# ─── Branding & identitas universitas (publik / NEXT_PUBLIC_*) ───
# Default sudah diisi untuk "Suara UNIGA Malang" (Universitas Gajayana
# Malang). Override semua nilai di bawah saat redeploy untuk kampus lain
# — TANPA edit kode. Catatan: penyebutan "UNIGA" di UI selalu disertai
# kata "Malang" karena ada kampus lain yang juga memakai singkatan UNIGA.
#
# Brand utama produk (judul tab browser, header navbar, OG title).
NEXT_PUBLIC_SITE_NAME=
NEXT_PUBLIC_UNIVERSITY_NAME=
NEXT_PUBLIC_UNIVERSITY_SHORT=
NEXT_PUBLIC_SITE_TAGLINE=
# Domain pendek tempat aplikasi di-host (mis. suara.unigamalang.ac.id).
NEXT_PUBLIC_APP_DOMAIN=
NEXT_PUBLIC_UNIVERSITY_URL=
NEXT_PUBLIC_CONTACT_EMAIL=
# Path logo di /public (mis. /img/uniga-logo.png).
NEXT_PUBLIC_LOGO_PATH=
# Path logo high-res untuk OpenGraph (mis. /img/uniga-logo@2x.png).
NEXT_PUBLIC_LOGO_OG_PATH=
NEXT_PUBLIC_LOGO_ALT=

# ─── Halaman /report (rekap masukan + kelola unit/prodi) ───
# Password yang dipakai pengelola universitas untuk masuk ke /report
# dan /report/units (CRUD daftar fakultas/prodi).
REPORT_PASSWORD=

# Optional: secret terpisah untuk menandatangani cookie sesi.
# Bila kosong, akan pakai REPORT_PASSWORD sebagai secret HMAC.
REPORT_SESSION_SECRET=

# ─── Google Sheets (storage masukan + sumber /report + daftar Units) ───
# Wajib. /api/saran menulis baris baru ke sheet ini, /report membacanya
# kembali, dan tab "Units" menyimpan daftar fakultas/prodi yang dipakai
# di form (cascade dropdown). ID spreadsheet ada di URL, bagian antara
# /d/ dan /edit.
REPORT_SHEET_ID=

# Optional: range / nama sheet, default "A:Z" pada sheet pertama.
# Skema kolom (12 kolom A–L): Timestamp | Saudara adalah | Unit/Prodi |
# Apakah Anonim? | Nama | NIM | Masukan (identitas) | Kronologi (identitas) |
# Kontak (identitas) | Masukan (anonim) | Kronologi (anonim) | Kontak (anonim).
# Contoh override: "Sheet1!A:L"
REPORT_SHEET_RANGE=

# Pilihan A — taruh seluruh JSON service account (1 baris) di sini.
# Cara: download file JSON dari GCP, lalu salin isinya ke sini sebagai single-line string.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Pilihan B — set kedua field ini secara terpisah (lebih ramah Vercel UI)
# Pakai \n untuk newline pada private key bila perlu.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
