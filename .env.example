# ─── Halaman /report (rekap masukan) ───
# Password yang dipakai pengelola FEB untuk masuk ke /report
REPORT_PASSWORD=

# Optional: secret terpisah untuk menandatangani cookie sesi.
# Bila kosong, akan pakai REPORT_PASSWORD sebagai secret HMAC.
REPORT_SESSION_SECRET=

# ─── Google Sheets (storage masukan + sumber /report) ───
# Wajib. /api/saran menulis baris baru ke sheet ini, dan /report
# membacanya kembali untuk rekap. ID spreadsheet ada di URL,
# bagian antara /d/ dan /edit.
REPORT_SHEET_ID=

# Optional: range / nama sheet, default "A:Z" pada sheet pertama.
# Skema kolom (12 kolom A–L): Timestamp | Saudara adalah | Unit/Prodi |
# Apakah Anonim? | Nama | NIM | Masukan (identitas) | Kronologi (identitas) |
# Kontak (identitas) | Masukan (anonim) | Kronologi (anonim) | Kontak (anonim).
# Contoh override: "Sheet1!A:L"
REPORT_SHEET_RANGE=

# Pilihan A — taruh seluruh JSON service account (1 baris) di sini.
# Cara: download file JSON dari GCP, lalu salin isinya ke sini sebagai single-line string.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Pilihan B — set kedua field ini secara terpisah (lebih ramah Vercel UI)
# Pakai \n untuk newline pada private key bila perlu.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
